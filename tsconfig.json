{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "declaration": true,
        "forceConsistentCasingInFileNames": true,
        "noEmitOnError": true,
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "example/**/*.ts"]
}
